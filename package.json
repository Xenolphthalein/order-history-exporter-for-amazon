{
  "name": "order-history-exporter-for-amazon",
  "version": "1.2.0",
  "description": "Export your Amazon order history as JSON or CSV files",
  "type": "module",
  "scripts": {
    "bump": "node scripts/bump.mjs",
    "build": "npm run typecheck && npm run lint && node build.js",
    "build:firefox": "npm run typecheck && npm run lint && node build.js --target=firefox",
    "build:chrome": "npm run typecheck && npm run lint && node build.js --target=chrome",
    "build:prod": "NODE_ENV=production npm run build",
    "build:prod:firefox": "NODE_ENV=production npm run build:firefox",
    "build:prod:chrome": "NODE_ENV=production npm run build:chrome",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "node -e \"const fs = require('fs'); if(fs.existsSync('dist')) fs.rmSync('dist', {recursive: true})\"",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "prepare": "husky"
  },
  "keywords": [
    "amazon",
    "order-history",
    "exporter",
    "browser-extension",
    "firefox",
    "chrome"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^6.17.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "webextension-polyfill": "0.12.0"
  }
}
